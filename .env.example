NEXT_PUBLIC_SUPABASE_URL=replace
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace
NEXT_PUBLIC_APP_URL=http://localhost:3000
SUPABASE_SERVICE_ROLE_KEY=replace

OPENAI_API_KEY=replace
HEADLINE_MODEL=gpt-4.1
BUILD_PROFILE_MODEL=gpt-5.5
OPENAI_TIMEOUT_MS=90000
OPENAI_MAX_RETRIES=2
NEXT_PUBLIC_ENABLE_GOOGLE_LOGIN=false
PROMPT_PROFILES_DIR=../prompt_profiles
GUIDELINES_DIR=../guidelines
ALLOWED_EMAIL_DOMAINS=followthemoney.nl,ftm.nl
ALLOWED_EMAILS=
# Optional explicit creator allowlist (comma-separated). If unset, creator access is DB-only via `user_roles`.
CREATOR_EMAILS=
DAILY_GENERATION_LIMIT=60
GLOBAL_DAILY_GENERATION_LIMIT=400
ALLOWED_FTM_EMAIL_DOMAINS=ftm.nl,followthemoney.nl
RESEND_API_KEY=
FTM_VERIFICATION_FROM_EMAIL=FTM Koppensneller <noreply@example.com>
FTM_VERIFICATION_SECRET=replace_with_long_random_string
FTM_VERIFICATION_CODE_TTL_MINUTES=15
# Comma-separated emails to receive weekly digest. If unset, no digest is sent.
WEEKLY_DIGEST_RECIPIENTS=
DIGEST_MODEL=gpt-4.1
CRON_SECRET=replace_with_long_random_string
